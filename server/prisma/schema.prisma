generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  username       String         @unique
  email          String         @unique
  passwordHash   String
  avatarUrl      String?
  displayName    String?
  bio            String?
  isOnline       Boolean        @default(false)
  lastSeenAt     DateTime?
  createdAt      DateTime       @default(now())
  conversations1 Conversation[] @relation("participant1")
  conversations2 Conversation[] @relation("participant2")
  sentMessages   Message[]      @relation("sender")
  reactions      Reaction[]
}

model Conversation {
  id             String    @id @default(cuid())
  participant1   User      @relation("participant1", fields: [participant1Id], references: [id])
  participant1Id String
  participant2   User      @relation("participant2", fields: [participant2Id], references: [id])
  participant2Id String
  messages       Message[]
  createdAt      DateTime  @default(now())
}

model Message {
  id             String       @id @default(cuid())
  content        String?
  fileUrl        String?
  seenAt         DateTime?
  deliveredAt    DateTime?
  deletedAt      DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String
  sender         User         @relation("sender", fields: [senderId], references: [id])
  senderId       String
  replyTo        Message?     @relation("replies", fields: [replyToId], references: [id])
  replyToId      String?
  replies        Message[]    @relation("replies")
  reactions      Reaction[]
  createdAt      DateTime     @default(now())
}

model Reaction {
  id        String  @id @default(cuid())
  emoji     String
  message   Message @relation(fields: [messageId], references: [id])
  messageId String
  user      User    @relation(fields: [userId], references: [id])
  userId    String

  @@unique([messageId, userId, emoji])
}